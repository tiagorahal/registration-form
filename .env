# Firebase Configuration
# Copie este arquivo para .env e preencha com suas credenciais do Firebase
# IMPORTANTE: Nunca commite o arquivo .env real no git!

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Exemplo de valores (NÃO USE ESTES, são apenas exemplos):
# VITE_FIREBASE_API_KEY=AIzaSyDOCAbC123dEf456GhI789jKl012-MnO
# VITE_FIREBASE_AUTH_DOMAIN=flugo-employee-reg.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=flugo-employee-reg
# VITE_FIREBASE_STORAGE_BUCKET=flugo-employee-reg.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
# VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456ghi789jkl